<style>
  .dl-submit-wrap {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    background: #f4ede1;
    color: #3a3a3a;
  }

  .dl-submit-wrap * { box-sizing: border-box; }

  .dl-submit-header {
    background: #6b1f1f;
    color: #f4ede1;
    padding: 2.5rem 1.5rem 2rem;
    text-align: center;
  }

  .dl-submit-header h1 {
    margin: 0 0 0.4rem;
    font-size: 1.9rem;
    letter-spacing: 0.03em;
  }

  .dl-submit-header p {
    margin: 0;
    opacity: 0.85;
    font-size: 0.95rem;
  }

  .dl-submit-form {
    max-width: 560px;
    margin: 2rem auto 3rem;
    padding: 0 1.5rem;
  }

  .dl-field {
    margin-bottom: 1.2rem;
  }

  .dl-field label {
    display: block;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    color: #3a3a3a;
  }

  .dl-field .dl-optional {
    color: #8a8a82;
    font-weight: normal;
  }

  .dl-field input,
  .dl-field select {
    width: 100%;
    padding: 0.7rem 0.8rem;
    border: 1px solid #cfc6b8;
    border-radius: 4px;
    font-size: 0.95rem;
    background: #ffffff;
    color: #3a3a3a;
  }

  .dl-field input::placeholder {
    color: #8a8a82;
  }

  .dl-field small {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    color: #8a8a82;
  }

  .dl-submit-button {
    width: 100%;
    background: #6b1f1f;
    color: #f4ede1;
    border: none;
    border-radius: 4px;
    padding: 0.85rem 1.1rem;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .dl-submit-button:hover:not(:disabled) {
    background: #4a1414;
  }

  .dl-submit-button:disabled {
    background: #8a8a82;
    cursor: default;
  }

  .dl-form-message {
    margin-top: 1rem;
    padding: 0.8rem 1rem;
    border-radius: 4px;
    font-size: 0.9rem;
    display: none;
    border: 1px solid #cfc6b8;
  }

  .dl-form-message.dl-success {
    display: block;
    background: #ffffff;
    color: #3a3a3a;
    border-color: #6b1f1f;
  }

  .dl-form-message.dl-error {
    display: block;
    background: #ffffff;
    color: #6b1f1f;
    border-color: #6b1f1f;
  }
</style>

<div class="dl-submit-wrap">

  <div class="dl-submit-header">
    <h1>Submit your photo</h1>
    <p>Enter this month's competition with your best frame developed at DarkLab</p>
  </div>

  <form class="dl-submit-form" id="dl-submit-form">

    <div class="dl-field">
      <label for="dl-name">Full name</label>
      <input type="text" id="dl-name" name="name" required>
    </div>

    <div class="dl-field">
      <label for="dl-email">Email address</label>
      <input type="email" id="dl-email" name="email" required>
    </div>

    <div class="dl-field">
      <label for="dl-month">Month developed</label>
      <select id="dl-month" name="month_developed" required>
        <option value="" disabled selected>Select the month</option>
        <option value="January">January</option>
        <option value="February">February</option>
        <option value="March">March</option>
        <option value="April">April</option>
        <option value="May">May</option>
        <option value="June">June</option>
        <option value="July">July</option>
        <option value="August">August</option>
        <option value="September">September</option>
        <option value="October">October</option>
        <option value="November">November</option>
        <option value="December">December</option>
      </select>
    </div>

    <div class="dl-field">
      <label for="dl-year">Year developed</label>
      <select id="dl-year" name="year_developed" required>
        <option value="" disabled selected>Select the year</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
        <option value="2027">2027</option>
        <option value="2028">2028</option>
      </select>
    </div>

    <div class="dl-field">
      <label for="dl-title">Photo title <span class="dl-optional">(optional)</span></label>
      <input type="text" id="dl-title" name="title" placeholder="Leave blank if you would rather not title it">
    </div>

    <div class="dl-field">
      <label for="dl-photo">Upload your photo</label>
      <input type="file" id="dl-photo" name="photo" accept="image/*" required>
      <small>Please upload the full resolution scan, this saves directly into our Drive folder.</small>
    </div>

    <button type="submit" class="dl-submit-button" id="dl-submit-button">Send entry</button>

    <div class="dl-form-message" id="dl-form-message"></div>

  </form>

</div>

<script>
(function() {
  var form = document.getElementById("dl-submit-form");
  var button = document.getElementById("dl-submit-button");
  var messageBox = document.getElementById("dl-form-message");

  form.addEventListener("submit", function(event) {
    event.preventDefault();

    button.disabled = true;
    button.textContent = "Sending...";
    messageBox.className = "dl-form-message";
    messageBox.textContent = "";

    var formData = new FormData(form);
    var SCRIPT_URL = "YOUR_APPS_SCRIPT_WEB_APP_URL_HERE";

    fetch(SCRIPT_URL, {
      method: "POST",
      mode: "no-cors",
      body: formData
    })
    .then(function() {
      messageBox.className = "dl-form-message dl-success";
      messageBox.textContent = "Thank you, your entry has been sent. Good luck!";
      form.reset();
      button.textContent = "Send entry";
      button.disabled = false;
    })
    .catch(function() {
      messageBox.className = "dl-form-message dl-error";
      messageBox.textContent = "Something went wrong sending your entry, please try again or email us directly.";
      button.textContent = "Send entry";
      button.disabled = false;
    });
  });
})();
</script>
